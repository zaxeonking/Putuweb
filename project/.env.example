# ============================================================
# KONFIGURASI GITHUB SEBAGAI "DATABASE"
# ============================================================
# Salin file ini menjadi ".env.local" untuk development lokal,
# lalu isi nilai-nilai di bawah sesuai repository GitHub Anda.
# Saat deploy ke Vercel, isi variable yang sama di:
# Project Settings -> Environment Variables

# Personal Access Token GitHub (Settings -> Developer settings ->
# Personal access tokens -> Fine-grained tokens).
# Minimal scope yang dibutuhkan: "Contents" = Read and write,
# pada repository yang dipakai untuk menyimpan data.
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Username / organisasi pemilik repository data
GITHUB_OWNER=username-github-anda

# Nama repository tempat file JSON database disimpan
GITHUB_REPO=kelasku-data

# Branch yang dipakai (default: main)
GITHUB_BRANCH=main

# Path file JSON di dalam repo (default: data/database.json)
GITHUB_DATA_PATH=data/database.json

# ============================================================
# KONFIGURASI AUTENTIKASI (LOGIN)
# ============================================================
# Username untuk login ke aplikasi. Hanya ada 1 akun admin (sederhana,
# tidak pakai database user).
ADMIN_USERNAME=admin

# --- Password: pilih SALAH SATU dari dua opsi di bawah ---

# Opsi 1 (SEDERHANA, cocok untuk belajar/development):
# password plaintext langsung. Jangan dipakai untuk aplikasi publik.
ADMIN_PASSWORD=kelas123

# Opsi 2 (DISARANKAN untuk production): hash bcrypt dari password.
# Kalau ADMIN_PASSWORD_HASH di-set, ADMIN_PASSWORD di atas akan diabaikan.
# Cara generate hash-nya, jalankan salah satu perintah berikut lalu
# salin hasilnya ke sini:
#   node -e "console.log(require('bcryptjs').hashSync('password-anda', 10))"
# ADMIN_PASSWORD_HASH=$2a$10$xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Secret key untuk menandatangani (sign) cookie session, supaya cookie
# tidak bisa dipalsukan/diubah oleh user. WAJIB DIISI, dan JANGAN dishare
# / commit ke git. Generate salah satu dengan perintah:
#   openssl rand -base64 32
# atau:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET=ganti-dengan-string-acak-yang-panjang-dan-rahasia

# ============================================================
# KONFIGURASI SEO / METADATA
# ============================================================
# URL production aplikasi (dipakai untuk metadataBase, og:image,
# robots.txt, dan sitemap.xml). Untuk development lokal biarkan default.
# Saat deploy ke Vercel, isi dengan domain asli, contoh:
#   https://kelasku.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
